{
  "name": "hidetaka-dev",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:component:watch": "vitest --config vitest.component.config.ts",
    "test:component:ui": "vitest --ui --config vitest.component.config.ts",
    "test:component:coverage": "vitest run --coverage --config vitest.component.config.ts",
    "pre-push": "pnpm lint:check && pnpm test && pnpm build",
    "sentry:sourcemaps": "sentry-cli sourcemaps upload --org=$SENTRY_ORG --project=$SENTRY_PROJECT .open-next",
    "cf:build": "opennextjs-cloudflare build",
    "cf:build:sentry": "pnpm cf:build && pnpm sentry:sourcemaps",
    "cf:preview": "pnpm cf:build && wrangler dev",
    "cf:dev": "pnpm cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "pnpm cf:build && opennextjs-cloudflare deploy",
    "cf:deploy:sentry": "pnpm cf:build:sentry && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@sentry/nextjs": "^10.55.0",
    "@types/turndown": "^5.0.6",
    "dayjs": "^1.11.7",
    "fast-xml-parser": "^5.8.0",
    "microcms-js-sdk": "^2.3.2",
    "next": "^16.2.6",
    "node-wp-api-client": "github:hideokamoto/node-wp-api-client#claude/magical-heisenberg-4ecizq",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "turndown": "^7.2.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=8.0.0 <8.0.6": ">=8.0.6",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "fast-xml-parser@>=5.0.0 <5.3.6": ">=5.3.6",
      "serialize-javascript": ">=7.0.5",
      "undici@>=6.0.0 <6.24.0": ">=6.24.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "fast-uri": ">=3.1.2",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "postcss": ">=8.5.10"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@sentry/cli": "^3.4.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dom-chromium-ai": "^0.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "fast-check": "^4.5.2",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.14",
    "typescript": "5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
