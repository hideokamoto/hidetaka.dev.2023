{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init.",
  "env": {
    "OTEL_RESOURCE_ATTRIBUTES": "project.name=hidetaka.dev.2023"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/pre-push-matcher.sh",
            "enabled": true,
            "type": "command"
          }
        ],
        "matcher": "bash"
      },
      {
        "hooks": [
          {
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 pnpm install --frozen-lockfile",
            "timeout": 60,
            "type": "command"
          },
          {
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 pnpm test",
            "timeout": 300,
            "type": "command"
          }
        ],
        "matcher": "Bash(git commit*)"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/session-start.sh",
            "enabled": true,
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  },
  "permissions": {
    "allow": ["Bash(chunk:*)"]
  }
}
